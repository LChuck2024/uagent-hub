# DeepSeek API Key（服务端调用；勿在前端 import.meta.env 读取）
VITE_DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# 主站 / 自引用链接
APP_URL="https://uagent.net"

# 租户与产品子域根域名（生产：*.uagent.net）
VITE_TENANT_DOMAIN="uagent.net"

# 可选：覆盖套件外链（本地未配 *.localhost 时可指向已部署地址）
# VITE_SUITE_API_URL="https://api.uagent.net"
# VITE_SUITE_STORM_URL="https://storm.uagent.net"
# VITE_SUITE_AUDIT_URL="https://audit.uagent.net"
