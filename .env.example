# VITE_DEEPSEEK_API_KEY: Required for DeepSeek AI API calls.
# Configure this in EdgeOne Pages environment variables for deployment.
VITE_DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_TENANT_DOMAIN: Root domain for multi-tenant subdomains (e.g. uagent.site).
# Production tenant URLs: https://{slug}.uagent.site
# Local dev tenant URLs:   http://{slug}.localhost:3000
VITE_TENANT_DOMAIN="uagent.site"
